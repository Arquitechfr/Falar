{
  "name": "falar-backend",
  "version": "1.0.0",
  "description": "Falar messaging backend — E2E encrypted, server never sees message content",
  "type": "module",
  "main": "src/app.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/app.ts",
    "start": "tsx --env-file=.env src/app.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "multer": "^2.0.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "tsx": "^4.22.4",
    "vitest": "^3.0.5"
  }
}
