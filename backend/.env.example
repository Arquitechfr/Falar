PORT=9000
MONGODB_URI=mongodb://localhost:27017/falar
# Redis
REDIS_HOST=62.210.92.214
REDIS_PORT=6379
REDIS_PASSWORD=PASSWORD

# JWT secrets — development values, replace in production
JWT_ACCESS_SECRET=dev_access_secret_change_in_production_2024
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_2024

# MinIO / S3
MINIO_ENDPOINT=assets.getpato.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=dev_access_key
MINIO_SECRET_KEY=dev_secret_key
MINIO_BUCKET=falar

# CORS
ALLOWED_ORIGINS=http://localhost:8081

# CI — token for GitHub Actions APK upload endpoint
CI_UPLOAD_TOKEN=ci_upload_token_change_in_production

# Twilio Verify
TWILIO_ENABLED=true
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid
